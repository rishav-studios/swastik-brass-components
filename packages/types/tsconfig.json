{
  "extends": "@swastik/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@swastik/ui/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "*.ts",
    "src/company.schema.ts",
    "src/enquiry.schema.ts",
    "src/facility.schema.ts",
    "src/product.schema.ts",
    "src/sector.schema.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
